# Токен вашего Telegram бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Ваш Telegram user ID (узнать у @userinfobot)
OWNER_CHAT_ID=your_telegram_id_here

# ID Google Таблицы (из URL: docs.google.com/spreadsheets/d/ЭТОТ_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Путь к файлу с ключами сервисного аккаунта Google
GOOGLE_CREDENTIALS_FILE=credentials.json

# URL фронтенда Mini App (после деплоя на Vercel)
MINI_APP_URL=https://your-app.vercel.app
